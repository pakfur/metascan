# ============================================================
# Project-specific
# ============================================================

# Runtime data — ignore everything under data/ except the
# vocabulary directory (tracked CLIP tag axes).
data/*
!data/vocabulary/

.claude/

# Other runtime artifacts
logs/
# Anchored so it only matches the root-level cache dir, not
# frontend/src/components/thumbnails/.
/thumbnails/
models/
gfpgan/
assets/media/
data/vocabulary/*.npz

# Local config (config_example.json is tracked)
config.json
config_dist.json

# AI agent scratch
WARP.md
docs/wireframes/

# ============================================================
