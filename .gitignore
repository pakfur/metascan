# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.eggs/
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
venv-*/
ENV/

# Tooling caches
.mypy_cache/
.dmypy.json
.pytest_cache/
.coverage
.coverage.*
.hypothesis/
htmlcov/
coverage.xml

